# Server environment variables.
# Copy to `.env` and fill in real values:  cp .env.example .env
# `.env` is gitignored — never commit real secrets.

# ── Server ──
# HTTP port the API listens on (optional; defaults to 5000).
PORT=5000

# ── Database ──
# MongoDB connection string (required). For Atlas, use a mongodb+srv URI.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<database>

# ── Auth ──
# Secret used to sign JWTs (required). Use a long, random string.
JWT_SECRET=replace-with-a-long-random-secret

# ── Admin seeding (optional) ──
# When both are set, a bootstrap admin is created on first start if none exists.
# seedAdmin warns and skips when these are unset.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
