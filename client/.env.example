# API base URL the client talks to.
SERVER_BASE_URL="http://localhost:5000/api"

# EmailJS configuration (client-side @emailjs/browser).
# These values ship in the client bundle and are designed to be public.
# Do NOT add the EmailJS private key here — it is for server-side use only.
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
